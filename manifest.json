{
  "manifest_version": 3,
  "name": "Easy Shortcut",
  "version": "1.0.0",
  "description": "Custom keyboard shortcuts for easy browser actions.",
  "permissions": [
    "tabs",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content_script.js"
      ]
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_popup": "options.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}